{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node18",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "noEmitOnError": true
  },
  "exclude": ["node_modules", "dist"]
}

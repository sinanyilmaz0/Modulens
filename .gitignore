# =============================================================================
# Modulens - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Bağımlılıklar
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Build / Derleme çıktıları
# -----------------------------------------------------------------------------
dist/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Test ve coverage çıktıları
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# npm pack / publish çıktıları
# -----------------------------------------------------------------------------
*.tgz
*.tar.gz

# -----------------------------------------------------------------------------
# Log dosyaları
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Environment ve hassas veriler
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# İşletim sistemi dosyaları
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE ve editör
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Geçici ve cache
# -----------------------------------------------------------------------------
*.tmp
*.temp
.cache/
.temp/
.tmp/
